    },
    {
      "caseId": "permission.default_deny.process",
      "title": "Process execution is denied by default",
      "category": "permission",
      "required": true,
      "capabilities": ["permission_default_deny"],
      "description": "Guest code cannot spawn processes unless explicitly granted.",
      "request": {
