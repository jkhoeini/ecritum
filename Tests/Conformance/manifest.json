{
  "schemaVersion": 1,
  "suite": "ecritum-conformance",
  "cases": [
    {
      "caseId": "allocation.public_c_release_coverage",
      "title": "Public C allocations have matching release coverage",
      "category": "allocation",
      "required": true,
      "capabilities": ["c_allocation_release"],
      "description": "Every public C allocation path has matching release or destroy coverage.",
      "expected": {
        "evidenceCommands": [
          "mise exec -- just test-c-abi-lifecycle",
          "mise exec -- just test-c-abi-host-registration",
          "mise exec -- just test-c-abi-eval",
          "mise exec -- just test-c-abi-policy-config"
        ]
      }
    },
    {
      "caseId": "error.script_to_structured_error",
      "title": "Script error converts to structured Ecritum error",
      "category": "error",
      "required": true,
      "capabilities": ["script_error"],
      "description": "A guest-language failure is reported as a structured Ecritum error.",
      "request": {
        "source": "raise a script error"
      },
      "expected": {
        "status": "ECRITUM_ERROR_SCRIPT",
        "category": "runtime",
        "operation": "eval"
      }
    },
    {
      "caseId": "eval.array",
      "title": "Eval returns array values",
      "category": "eval",
      "required": true,
      "capabilities": ["eval"],
      "description": "A script can return an array value with typed elements.",
      "request": {
        "source": "return [1, \"two\", true]"
      },
      "expected": {
        "value": {
          "kind": "array",
          "value": [
            {"kind": "int", "value": 1},
            {"kind": "string", "value": "two"},
            {"kind": "bool", "value": true}
          ]
        }
      }
    },
    {
      "caseId": "eval.object",
      "title": "Eval returns object values",
      "category": "eval",
      "required": true,
      "capabilities": ["eval"],
      "description": "A script can return an object value with string keys.",
      "request": {
        "source": "return {\"answer\": 42}"
      },
      "expected": {
        "value": {
          "kind": "object",
          "value": {
            "answer": {"kind": "int", "value": 42}
          }
        }
      }
    },
    {
      "caseId": "eval.scalar",
      "title": "Eval returns scalar values",
      "category": "eval",
      "required": true,
      "capabilities": ["eval"],
      "description": "A script can return a scalar value without losing its Ecritum value kind.",
      "request": {
        "source": "return 42"
      },
      "expected": {
        "value": {"kind": "int", "value": 42}
      }
    },
    {
      "caseId": "host.host_function_returns_value",
      "title": "Host function returns value to script",
      "category": "host",
      "required": true,
      "capabilities": ["host_call"],
      "description": "A host callback can return a typed Ecritum value to guest code.",
      "request": {
        "hostFunction": "app.answer"
      },
      "expected": {
        "value": {"kind": "int", "value": 42}
      }
    },
    {
      "caseId": "host.script_calls_host_function",
      "title": "Script calls host function",
      "category": "host",
      "required": true,
      "capabilities": ["host_call"],
      "description": "A script can call an explicitly registered host function.",
      "request": {
        "hostFunction": "app.notify"
      },
      "expected": {
        "hostCalls": [
          {"namespace": "app", "function": "notify"}
        ]
      }
    },
    {
      "caseId": "lifecycle.c.create_destroy_no_leak",
      "title": "C lifecycle create and destroy paths do not leak",
      "category": "lifecycle",
      "required": true,
      "capabilities": ["c_lifecycle"],
      "description": "Runtime, context, namespace, function, and error handles are released through the public C ABI.",
      "expected": {
        "evidenceCommands": [
          "mise exec -- just test-c-abi-lifecycle",
          "mise exec -- just test-c-abi-asan",
          "mise exec -- just test-c-abi-host-registration",
          "mise exec -- just test-c-abi-host-registration-asan",
          "mise exec -- just test-c-abi-eval",
          "mise exec -- just test-c-abi-eval-asan"
        ]
      }
    },
    {
      "caseId": "lifecycle.swift.create_destroy_no_leak",
      "title": "Swift lifecycle create and destroy paths do not leak",
      "category": "lifecycle",
      "required": true,
      "capabilities": ["swift_lifecycle"],
      "description": "Swift runtime, context, namespace, and function wrappers release their owned C handles exactly once.",
      "expected": {
        "evidenceCommands": [
          "mise exec -- just test-swift-scaffold"
        ]
      }
    },
    {
      "caseId": "model.swift.policy_config_serialization",
      "title": "Swift policy config serializes to schema v1",
      "category": "model",
      "required": false,
      "capabilities": ["policy_config"],
      "description": "Swift policy/config models serialize to the deny-by-default schema consumed by the C ABI.",
      "expected": {
        "evidenceCommands": [
          "mise exec -- just test-swift-scaffold",
          "mise exec -- just test-c-abi-policy-config"
        ]
      }
    },
    {
      "caseId": "model.swift.structured_errors",
      "title": "Swift structured errors preserve safe diagnostics",
      "category": "model",
      "required": false,
      "capabilities": ["swift_error_model"],
      "description": "Swift structured errors preserve status/category while redacting unsafe diagnostics.",
      "expected": {
        "evidenceCommands": [
          "mise exec -- just test-swift-scaffold"
        ]
      }
    },
    {
      "caseId": "model.swift.value_kinds",
      "title": "Swift value model preserves all M2 value kinds",
      "category": "model",
      "required": false,
      "capabilities": ["swift_value_model"],
      "description": "Swift value modeling preserves null, bool, int, double, string, data, array, and object values.",
      "expected": {
        "evidenceCommands": [
          "mise exec -- just test-swift-scaffold"
        ]
      }
    },
    {
      "caseId": "permission.default_deny.class_loading",
      "title": "Class loading is denied by default",
      "category": "permission",
      "required": true,
      "capabilities": ["permission_default_deny"],
      "description": "Guest code cannot load arbitrary classes unless the host explicitly grants a capability.",
      "request": {
        "attempt": "class_loading"
      },
      "expected": {
        "status": "ECRITUM_ERROR_PERMISSION_DENIED"
      }
    },
    {
      "caseId": "permission.default_deny.environment",
