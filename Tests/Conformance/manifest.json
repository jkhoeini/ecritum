        "status": "ECRITUM_ERROR_PERMISSION_DENIED"
      }
    },
    {
      "caseId": "permission.default_deny.reflection",
      "title": "Reflection is denied by default",
      "category": "permission",
      "required": true,
      "capabilities": ["permission_default_deny"],
      "description": "Guest code cannot use reflection escape hatches unless explicitly granted.",
      "request": {
        "attempt": "reflection"
      },
      "expected": {
        "status": "ECRITUM_ERROR_PERMISSION_DENIED"
      }
    },
    {
      "caseId": "permission.default_deny.unrestricted_java_lookup",
      "title": "Unrestricted Java lookup is denied by default",
      "category": "permission",
      "required": true,
      "capabilities": ["permission_default_deny"],
      "description": "Guest code cannot perform unrestricted Java lookup unless explicitly granted.",
      "request": {
        "attempt": "unrestricted_java_lookup"
      },
      "expected": {
        "status": "ECRITUM_ERROR_PERMISSION_DENIED"
      }
    },
    {
      "caseId": "permission.filesystem.allowed_root_inside",
      "title": "Allowed filesystem root permits access inside the root",
      "category": "permission",
      "required": true,
      "capabilities": ["filesystem_allowed_root"],
      "description": "A filesystem capability permits access inside its configured root only.",
      "request": {
        "attempt": "filesystem_inside_allowed_root"
      },
      "expected": {
        "status": "ECRITUM_OK"
      }
    },
    {
      "caseId": "permission.filesystem.allowed_root_outside_denied",
      "title": "Allowed filesystem root denies access outside the root",
      "category": "permission",
      "required": true,
      "capabilities": ["filesystem_allowed_root"],
      "description": "A filesystem capability denies path traversal outside its configured root.",
      "request": {
        "attempt": "filesystem_outside_allowed_root"
      },
      "expected": {
        "status": "ECRITUM_ERROR_PERMISSION_DENIED"
      }
    },
    {
      "caseId": "timeout.long_running_script",
      "title": "Timeout cancels long-running script",
      "category": "timeout",
      "required": true,
      "capabilities": ["timeout"],
      "description": "A long-running script reaches terminal timeout/cancel status per ADR-014.",
      "request": {
        "source": "run forever",
        "executionTimeoutNanos": 1000000
      },
      "expected": {
        "status": "ECRITUM_ERROR_TIMEOUT"
      }
    }
  ]
}
