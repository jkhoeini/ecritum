      }
    },
    {
      "caseId": "permission.default_deny.network",
      "title": "Network access is denied by default",
      "category": "permission",
      "required": true,
      "capabilities": ["permission_default_deny"],
      "description": "Guest code cannot open network connections unless explicitly granted.",
      "request": {
